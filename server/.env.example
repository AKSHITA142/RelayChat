# Environment variables for Render deployment
NODE_ENV=production
PORT=5002

# Backend URL (for CSP and CORS)
BASE_URL=https://relaychat-backend.onrender.com

# MongoDB Database
MONGODB_URI=mongodb+srv://your_username:your_password@your_cluster.mongodb.net/relaychat?retryWrites=true&w=majority

# JWT Secret
JWT_SECRET=your_super_secret_jwt_key_here

# Email OTP (Resend)
RESEND_API_KEY=your_resend_api_key_here
# Use a verified sender/domain in production (e.g. no-reply@yourdomain.com)
RESEND_FROM=onboarding@resend.dev

# OTP settings
OTP_SECRET=your_otp_hashing_secret_here
OTP_TTL_SECONDS=300
OTP_COOLDOWN_SECONDS=60
OTP_MAX_ATTEMPTS=5

# CORS (your frontend URL)
# You can provide one or more origins (comma-separated).
CORS_ORIGIN=https://your-vercel-app-url.vercel.app

# Optional: override dev/test origins (comma-separated). If unset, a localhost default list is used.
# CORS_DEV_ORIGINS=http://localhost:5173,http://localhost:3000
CORS_DEV_ORIGINS=

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads
