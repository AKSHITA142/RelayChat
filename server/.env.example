# Environment variables for Render deployment
NODE_ENV=production
PORT=5002

# Backend URL (for CSP and CORS)
BASE_URL=https://relaychat-backend.onrender.com

# MongoDB Database
MONGODB_URI=mongodb+srv://your_username:your_password@your_cluster.mongodb.net/relaychat?retryWrites=true&w=majority

# JWT Secret
JWT_SECRET=your_super_secret_jwt_key_here

# Redis (if using)
REDIS_URL=redis://default:your_password@your-redis-host:port

# Twilio (for SMS)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number

# CORS (your frontend URL)
CORS_ORIGIN=https://your-vercel-app-url.vercel.app

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads
